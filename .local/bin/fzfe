#!/usr/bin/env bash

# fzfe - Fuzzy Finder File Explorer
#
# Usage: fzfe [directory]
#
# Inspired by https://github.com/ashish0kumar/fzfm/tree/main and
# https://thevaluable.dev/practical-guide-fzf-example/

SCRIPT="$(realpath "$0")"

# Command used to open media files (override via FZFE_MEDIA_OPENER).
FZFE_MEDIA_OPENER="${FZFE_MEDIA_OPENER:-open}"
# Editor for text/binary files (override via FZFE_TEXT_EDITOR).
FZFE_TEXT_EDITOR="${FZFE_TEXT_EDITOR:-nvim}"
# Command used to list directory entries (override via FZFE_LIST_COMMAND).
FZFE_LIST_COMMAND="${FZFE_LIST_COMMAND:-ls -a --color}"
# Command used to preview files (override via FZFE_PREVIEW_COMMAND).
FZFE_PREVIEW_COMMAND="${FZFE_PREVIEW_COMMAND:-bat}"
# Clipboard file holding the copy / move marks. A stable, shared path (override
# via FZFE_CLIPBOARD) so a selection copied / moved in one fzfe instance can be
# pasted in another, like the previous /tmp/fzfe-files behaviour. The first line
# is the operation (cp / mv); the remaining lines are the absolute source paths.
FZFE_CLIPBOARD="${FZFE_CLIPBOARD:-${TMPDIR:-/tmp}/fzfe-clipboard}"
# strftime format for the modification-time column (override via
# FZFE_TIME_FORMAT). Keep it fixed-width so the name column stays aligned.
FZFE_TIME_FORMAT="${FZFE_TIME_FORMAT:-%Y-%m-%d %H:%M}"
# Startup sort order: "name" (A->Z) or "modified" (newest first). Toggled at
# runtime with alt-s; override just the startup default via FZFE_DEFAULT_SORT.
FZFE_DEFAULT_SORT="${FZFE_DEFAULT_SORT:-name}"

# ---------- List mode ----------
#
# Called for the initial feed and on every reload. Lists the entries of the
# current working directory (the fzf child processes inherit the directory the
# explorer navigated into) as aligned rows of "permissions size modified name".
# Only the trailing name is meant to be searchable (see --nth in the main
# mode); the metadata is dimmed and the name is colored by ls itself.

if [[ "$1" == "__list" ]]; then
  tf="$FZFE_TIME_FORMAT"
  mode="$(cat "$FZFE_SORT_STATE" 2>/dev/null)"
  [[ "$mode" != "modified" ]] && mode="name"

  # Fixed width of the timestamp column so the name column lines up.
  sample="$(date +"$tf")"
  tw="${#sample}"

  # Collect entry names (including . .. and dotfiles), one per line.
  names=()
  while IFS= read -r entry; do
    [[ -n "$entry" ]] && names+=("$entry")
  done < <(ls -a -1)
  [[ ${#names[@]} -eq 0 ]] && exit 0

  # Pair each entry's metadata with the name colored by ls itself, so every
  # file type (directory, symlink, executable, socket, sticky / other-writable
  # directory, ...) matches `ls` exactly and honors any custom LSCOLORS. Both
  # lists come from the same `ls -a` ordering, so paste aligns them 1:1. Tab
  # separated so names with spaces stay intact. Columns:
  #   epoch <tab> perms <tab> bytes <tab> time <tab> name <tab> colored-name
  combined="$(paste \
    <(stat -f $'%m\t%Sp\t%z\t%Sm\t%N' -t "$tf" -- "${names[@]}" 2>/dev/null) \
    <(ls -a -1 --color))"
  [[ -z "$combined" ]] && exit 0

  # Renders one row: dimmed, aligned metadata columns (with a human-readable
  # size, powers of 1024, matching `ls -lh`) followed by the ls-colored name.
  fmt='
    function human(b,  s, u) {
      split("B,K,M,G,T,P", u, ",")
      s = 1
      while (b >= 1024 && s < 6) { b /= 1024; s++ }
      return (s == 1) ? sprintf("%d%s", b, u[s]) \
                      : sprintf((b < 10 ? "%.1f%s" : "%.0f%s"), b, u[s])
    }
    {
      printf "\033[2m%-10s  %6s  %-*s\033[0m  %s\n", $2, human($3 + 0), tw, $4, $6
    }'

  if [[ "$mode" == "modified" ]]; then
    # Keep . and .. pinned at the top; sort the rest by mtime, newest first.
    {
      printf '%s\n' "$combined" | awk -F'\t' '$5 == "." || $5 == ".."'
      printf '%s\n' "$combined" | awk -F'\t' '$5 != "." && $5 != ".."' | sort -t$'\t' -k1,1nr
    } | awk -F'\t' -v tw="$tw" "$fmt"
  else
    # Alphabetical order (ls -a already sorts this way, with . and .. first).
    printf '%s\n' "$combined" | awk -F'\t' -v tw="$tw" "$fmt"
  fi
  exit 0
fi

# ---------- Sort toggle ----------
#
# Flips the per-instance sort state between "name" and "modified". Bound to
# alt-s in the main mode and followed by a reload.

if [[ "$1" == "__togglesort" ]]; then
  if [[ "$(cat "$FZFE_SORT_STATE" 2>/dev/null)" == "modified" ]]; then
    printf 'name\n' > "$FZFE_SORT_STATE"
  else
    printf 'modified\n' > "$FZFE_SORT_STATE"
  fi
  exit 0
fi

# ---------- Preview mode ----------
#
# Renders directory contents for folders and a syntax-highlighted view for
# files. Called from the fzf --preview binding as: fzfe __preview <entry>

if [[ "$1" == "__preview" ]]; then
  file="$2"
  [[ -z "$file" ]] && exit 0

  if [[ -d "$file" ]]; then
    echo "󰉋 Folder: $file"
    echo ""
    $FZFE_LIST_COMMAND "$file" 2>/dev/null
  elif [[ -f "$file" ]]; then
    echo "󰈙 File: $file"
    echo ""
    if [[ "$file" == *.md || "$file" == *.markdown ]]; then
      glow --style=auto "$file" 2>/dev/null \
        || $FZFE_PREVIEW_COMMAND --style=numbers --color=always "$file" 2>/dev/null \
        || cat "$file"
    else
      $FZFE_PREVIEW_COMMAND --style=numbers --color=always "$file" 2>/dev/null \
        || cat "$file"
    fi
  else
    echo "Invalid selection: $file"
  fi
  exit 0
fi

# ---------- Action handlers ----------
#
# Called recursively from fzf bindings as:
#   fzfe __action <action> [entries...]
#
# Marks recorded by copy / move are stored in the shared clipboard file
# (FZFE_CLIPBOARD): the first line is the operation (cp / mv) and the remaining
# lines are the absolute source paths.

if [[ "$1" == "__action" ]]; then
  shift
  action="$1"
  shift

  case "$action" in
    open)
      file="$1"
      [[ -z "$file" ]] && exit 0
      mime_type=$(file --mime-type -b "$file")

      case "$mime_type" in
        text/*|application/json|application/xml|application/javascript|application/x-shellscript)
          $FZFE_TEXT_EDITOR "$file"
          clear
          ;;
        image/*|video/*|audio/*|application/pdf)
          if [[ -n "$FZFE_MEDIA_OPENER" ]]; then
            $FZFE_MEDIA_OPENER "$file" &>/dev/null &
          else
            echo "No media opener available. Cannot open $file"
            read -n 1 -s -r -p "Press any key to continue..."
            clear
          fi
          ;;
        *)
          if [ -B "$file" ]; then
            $FZFE_TEXT_EDITOR "$file"
            clear
          elif [[ -n "$FZFE_MEDIA_OPENER" ]]; then
            $FZFE_MEDIA_OPENER "$file" &>/dev/null || {
              $FZFE_TEXT_EDITOR "$file"
              clear
            }
          else
            $FZFE_TEXT_EDITOR "$file"
            clear
          fi
          ;;
      esac
      ;;

    yank)
      [[ $# -eq 0 ]] && exit 0
      {
        for f in "$@"; do
          [[ -n "$f" ]] && realpath "$f"
        done
      } | pbcopy
      ;;

    copy|move)
      [[ $# -eq 0 || -z "$FZFE_CLIPBOARD" ]] && exit 0
      op="cp"
      [[ "$action" == "move" ]] && op="mv"
      {
        printf '%s\n' "$op"
        for f in "$@"; do
          [[ -n "$f" ]] && realpath "$f"
        done
      } > "$FZFE_CLIPBOARD"
      ;;

    paste)
      [[ -z "$FZFE_CLIPBOARD" || ! -s "$FZFE_CLIPBOARD" ]] && exit 0
      op="$(sed -n '1p' "$FZFE_CLIPBOARD")"
      target="$(pwd)"

      ok=1
      while IFS= read -r f || [[ -n "$f" ]]; do
        [[ -z "$f" ]] && continue
        if [[ "$op" == "cp" ]]; then
          cp -r "$f" "$target" || ok=0
        elif [[ "$op" == "mv" ]]; then
          mv "$f" "$target" || ok=0
        fi
      done < <(sed '1d' "$FZFE_CLIPBOARD")

      # A move empties the clipboard (the sources no longer exist); a copy keeps
      # it so the selection can be pasted into several directories.
      [[ "$op" == "mv" ]] && : > "$FZFE_CLIPBOARD"

      if [[ $ok -eq 0 ]]; then
        read -n 1 -s -r -p "Press any key to continue..."
      fi
      ;;

    delete)
      [[ $# -eq 0 ]] && exit 0
      confirm="$(printf '%s\n' "No" "Yes" | fzf \
        --bind "ctrl-d:half-page-down" \
        --bind "ctrl-u:half-page-up" \
        --prompt "󰩺 Delete $# item(s): " \
        --height 100% \
        --reverse \
        --border rounded)"
      if [[ "$confirm" == "Yes" ]]; then
        for f in "$@"; do
          [[ -n "$f" ]] && rm -r "$f"
        done
      fi
      ;;

    rename)
      old="$1"
      [[ -z "$old" || "$old" == "." || "$old" == ".." ]] && exit 0
      [[ ! -e "$old" && ! -L "$old" ]] && exit 0

      # mv-based rename within the current directory. The edit box is prefilled
      # with the current name so only the part that changes has to be typed.
      #
      # macOS ships bash 3.2, which lacks `read -i` for a prefilled prompt, so
      # the box is an fzf query seeded with the current name over an empty
      # candidate list: Enter prints the (edited) query, Esc cancels.
      new="$(fzf --print-query --query "$old" \
        --prompt "Rename to: " \
        --height 100% \
        --reverse \
        --border rounded \
        --border-label " 󰏫 rename $old " \
        --border-label-pos center \
        --header "Edit the name, then Enter (Esc to cancel)" \
        < /dev/null)"
      rc=$?
      # 0 = match accepted, 1 = query accepted (no match); anything else (130
      # Esc, 2 error) means cancel.
      [[ $rc -ne 0 && $rc -ne 1 ]] && exit 0
      new="$(printf '%s\n' "$new" | head -1)"
      [[ -z "$new" || "$new" == "$old" ]] && exit 0
      if [[ -e "$new" || -L "$new" ]]; then
        echo "Target already exists: $new"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi
      mv -- "$old" "$new" || {
        echo "Rename failed."
        read -n 1 -s -r -p "Press any key to continue..."
      }
      ;;

    *)
      echo "Unknown action: $action"
      exit 1
      ;;
  esac
  exit 0
fi

# ---------- Main mode ----------

usage() {
  cat <<'EOF'
fzfe - Fuzzy Finder File Explorer

Usage: fzfe [directory]

Examples:
  fzfe
  fzfe ~/Documents
  fzfe /tmp

If a directory is given, browsing starts there; otherwise the current
working directory is used. Select ".." to move to the parent directory and
select a directory to enter it.

Each row shows the entry's permissions, human-readable size and last
modification time, followed by the name. Only the name is searchable.

Keybindings:
  enter     : open the file / enter the directory
  tab       : select item and move down
  shift-tab : select item and move up
  alt-a     : select all
  alt-x     : deselect all
  alt-y     : copy absolute paths of the selection to the clipboard
  alt-c     : mark the selection to be copied (paste with alt-p)
  alt-m     : mark the selection to be moved (paste with alt-p)
  alt-p     : paste the copied/moved selection into the current directory
  alt-r     : rename the item under the cursor (mv)
  alt-d     : delete the selection (rm -r, with confirmation)
  alt-s     : toggle sort order (name A->Z / modified newest first)
  ctrl-r    : reload the list
  ctrl-p    : toggle preview
  ctrl-d    : half page down
  ctrl-u    : half page up
  ctrl-f    : preview half page down
  ctrl-b    : preview half page up
  home      : scroll preview to top
  end       : scroll preview to bottom

The preview shows directory contents for folders and a syntax-highlighted
view for files.

Environment:
  FZFE_MEDIA_OPENER    Command to open media files (default: open)
  FZFE_TEXT_EDITOR     Editor for text/binary files (default: nvim)
  FZFE_LIST_COMMAND    Command used to preview folder contents
                       (default: ls -a --color)
  FZFE_PREVIEW_COMMAND Command used to preview files (default: bat)
  FZFE_TIME_FORMAT     strftime format for the time column
                       (default: %Y-%m-%d %H:%M)
  FZFE_DEFAULT_SORT    Startup sort order, name or modified (default: name)
EOF
}

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  usage
  exit 0
fi

# An optional directory argument selects where browsing starts.
if [[ -n "$1" ]]; then
  if [[ -d "$1" ]]; then
    cd "$1" || exit 1
  else
    echo "Not a directory: $1" >&2
    exit 1
  fi
fi

# Per-instance sort state (name | modified). A PID-scoped path so the order
# resets on each fresh fzfe launch and never leaks between concurrent instances.
FZFE_SORT_STATE="${TMPDIR:-/tmp}/fzfe-sort-$$"
sort_default="$FZFE_DEFAULT_SORT"
[[ "$sort_default" != "modified" ]] && sort_default="name"
printf '%s\n' "$sort_default" > "$FZFE_SORT_STATE"
trap 'rm -f "$FZFE_SORT_STATE"' EXIT

# Number of leading (whitespace-delimited) metadata columns before the name:
# permissions + size + however many words the timestamp format expands to. This
# keeps search (--nth) and name extraction correct even for a custom
# FZFE_TIME_FORMAT.
time_words="$(date +"$FZFE_TIME_FORMAT" | wc -w | tr -d '[:space:]')"
[[ "$time_words" =~ ^[0-9]+$ ]] || time_words=2
[[ "$time_words" -lt 1 ]] && time_words=2
meta_fields=$((2 + time_words))
name_field=$((meta_fields + 1))

# Export the resolved configuration (including the shared clipboard path and the
# sort state) so the child __list / __preview / __action / __togglesort
# processes use the same values.
export FZFE_CLIPBOARD FZFE_MEDIA_OPENER FZFE_TEXT_EDITOR FZFE_LIST_COMMAND FZFE_PREVIEW_COMMAND FZFE_TIME_FORMAT FZFE_SORT_STATE

ACTION="$SCRIPT __action"

clear
while true; do
  selection=$("$SCRIPT" __list | fzf \
    --ansi \
    --multi \
    --reverse \
    --height 100% \
    --info right \
    --nth "${name_field}.." \
    --prompt "󰥨 Search: " \
    --pointer ">" \
    --marker "󰄲" \
    --border "rounded" \
    --border-label " 󱉭 $(pwd)/ " \
    --border-label-pos center \
    --bind "ctrl-d:half-page-down" \
    --bind "ctrl-u:half-page-up" \
    --bind "ctrl-f:preview-half-page-down" \
    --bind "ctrl-b:preview-half-page-up" \
    --bind "home:preview-top" \
    --bind "end:preview-bottom" \
    --bind "ctrl-p:toggle-preview" \
    --bind "alt-s:execute-silent($SCRIPT __togglesort)+reload($SCRIPT __list)" \
    --bind "tab:toggle+down" \
    --bind "shift-tab:toggle+up" \
    --bind "alt-a:select-all" \
    --bind "alt-x:deselect-all" \
    --bind "ctrl-r:reload($SCRIPT __list)" \
    --bind "alt-y:execute($ACTION yank {+${name_field}..})" \
    --bind "alt-c:execute($ACTION copy {+${name_field}..})+deselect-all" \
    --bind "alt-m:execute($ACTION move {+${name_field}..})+deselect-all" \
    --bind "alt-p:execute($ACTION paste)+reload($SCRIPT __list)" \
    --bind "alt-r:execute($ACTION rename {${name_field}..})+reload($SCRIPT __list)" \
    --bind "alt-d:execute($ACTION delete {+${name_field}..})+reload($SCRIPT __list)" \
    --bind "enter:accept" \
    --preview-window "right:65%" \
    --preview "$SCRIPT __preview {${name_field}..}")

  [[ -z "$selection" ]] && break

  # The accepted line still carries the metadata columns; strip them to recover
  # the entry name (which may itself contain spaces).
  name="$(printf '%s' "$selection" | sed -E "s/^([^[:space:]]+[[:space:]]+){${meta_fields}}//")"

  if [[ "$name" == ".." ]]; then
    cd .. || break
  elif [[ -d "$name" ]]; then
    cd "$name" || break
  elif [[ -e "$name" ]]; then
    "$SCRIPT" __action open "$name"
  else
    break
  fi
done
