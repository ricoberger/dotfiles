#!/usr/bin/env bash

# fzfk - Fuzzy Finder for Kubernetes
#
# Usage: fzfk <resource> [kubectl get args...]

SCRIPT="$(realpath "$0")"

# ---------- Action handlers ----------
#
# Called recursively from fzf bindings as:
#   fzfk __action <action> <resource> <namespace_or_-> <name>
#   fzfk __action delete <resource> <all_ns> <fixed_ns_or_-> <row>...
#
# The sentinel "-" is used for the namespace when no namespace was given
# (i.e. the current kubectl context's namespace should be used). The delete
# action supports multiple rows and therefore uses its own argument layout;
# see the "delete" branch below.

if [[ "$1" == "__action" ]]; then
  shift
  action="$1"
  resource="$2"

  # The delete action can operate on several resources at once, so it uses a
  # dedicated argument layout:
  #   fzfk __action delete <resource> <all_ns> <fixed_ns_or_-> <row>...
  # Each <row> is a full "kubectl get" output line as passed by fzf's {+}
  # placeholder (the marked rows, or the row under the cursor when nothing is
  # marked). In -A mode the namespace is the row's first column and the name
  # its second; otherwise the name is the first column and the namespace is
  # <fixed_ns> ("-" for the context default).
  if [[ "$action" == "delete" ]]; then
    all_ns="$3"
    fixed_ns="$4"
    shift 4

    targets=()   # entries of the form "<namespace_or_->\t<name>"
    labels=()    # human-readable rows shown in the confirmation header
    for row in "$@"; do
      [[ -z "${row//[[:space:]]/}" ]] && continue
      if [[ "$all_ns" == "true" ]]; then
        row_ns="$(awk '{print $1}' <<<"$row")"
        row_name="$(awk '{print $2}' <<<"$row")"
      else
        row_ns="$fixed_ns"
        row_name="$(awk '{print $1}' <<<"$row")"
      fi
      [[ -z "$row_name" ]] && continue
      targets+=("$row_ns"$'\t'"$row_name")
      if [[ -n "$row_ns" && "$row_ns" != "-" ]]; then
        labels+=("$resource/$row_name (ns: $row_ns)")
      else
        labels+=("$resource/$row_name")
      fi
    done
    [[ ${#targets[@]} -eq 0 ]] && exit 0

    confirm="$(printf '%s\n' "No" "Yes" "Yes (force)" | fzf \
      --prompt "󰩺 Confirm delete (${#targets[@]}): " \
      --header "$(printf '%s\n' "${labels[@]}")" \
      --height 100% \
      --reverse \
      --border rounded)"
    [[ "$confirm" != "Yes" && "$confirm" != "Yes (force)" ]] && exit 0

    force_args=()
    [[ "$confirm" == "Yes (force)" ]] && force_args=(--grace-period=0 --force)

    for target in "${targets[@]}"; do
      del_ns="${target%%$'\t'*}"
      del_name="${target#*$'\t'}"
      del_ns_arg=()
      [[ -n "$del_ns" && "$del_ns" != "-" ]] && del_ns_arg=(-n "$del_ns")
      kubectl delete "${del_ns_arg[@]}" "${force_args[@]}" "$resource" "$del_name"
    done
    read -n 1 -s -r -p "Press any key to continue..."
    exit 0
  fi

  namespace="$3"
  name="$4"

  ns_arg=()
  if [[ -n "$namespace" && "$namespace" != "-" ]]; then
    ns_arg=(-n "$namespace")
  fi

  case "$action" in
    describe)
      kubectl describe "${ns_arg[@]}" "$resource" "$name" | nvim
      ;;

    yaml)
      kubectl get "${ns_arg[@]}" "$resource" "$name" -o yaml | nvim
      ;;

    logs)
      containers=$(kubectl get "${ns_arg[@]}" "$resource" "$name" -o jsonpath='{.spec.containers[*].name} {.spec.template.spec.containers[*].name} {.spec.initContainers[*].name} {.spec.template.spec.initContainers[*].name}' 2>/dev/null \
        | tr ' ' '\n' | awk 'NF && !seen[$0]++')
      if [[ -z "$containers" ]]; then
        echo "No containers found for $resource/$name"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi
      container=$(echo "$containers" | fzf \
        --prompt "󰆧 Container: " \
        --height 100% \
        --reverse \
        --border rounded)
      [[ -z "$container" ]] && exit 0
      kubectl logs "${ns_arg[@]}" "$resource/$name" -c "$container" --tail=500 -f
      ;;

    exec)
      containers=$(kubectl get "${ns_arg[@]}" "$resource" "$name" -o jsonpath='{.spec.containers[*].name} {.spec.template.spec.containers[*].name}' 2>/dev/null \
        | tr ' ' '\n' | awk 'NF && !seen[$0]++')
      if [[ -z "$containers" ]]; then
        echo "No containers found for $resource/$name"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi
      container=$(echo "$containers" | fzf \
        --prompt "󰆧 Container: " \
        --height 100% \
        --reverse \
        --border rounded)
      [[ -z "$container" ]] && exit 0
      kubectl exec "${ns_arg[@]}" -it "$resource/$name" -c "$container" -- \
        sh -c 'command -v bash >/dev/null 2>&1 && exec bash || exec sh'
      ;;

    portforward)
      ports=$(kubectl get "${ns_arg[@]}" "$resource" "$name" -o jsonpath='{.spec.containers[*].ports[*].containerPort} {.spec.template.spec.containers[*].ports[*].containerPort} {.spec.ports[*].port}' 2>/dev/null \
        | tr ' ' '\n' | awk 'NF && !seen[$0]++' | sort -n)
      if [[ -z "$ports" ]]; then
        echo "No ports found for $resource/$name"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi
      port=$(echo "$ports" | fzf \
        --prompt "󰮏 Port: " \
        --height 100% \
        --reverse \
        --border rounded)
      [[ -z "$port" ]] && exit 0
      printf "Local port [%s]: " "$port"
      read -r local_port
      local_port=${local_port:-$port}
      echo "Forwarding $resource/$name $local_port -> $port (Ctrl-C to stop)"
      kubectl port-forward "${ns_arg[@]}" "$resource/$name" "$local_port:$port"
      read -n 1 -s -r -p "Press any key to continue..."
      ;;

    *)
      echo "Unknown action: $action"
      exit 1
      ;;
  esac
  exit 0
fi

# ---------- Main mode ----------

usage() {
  cat <<'EOF'
fzfk - Fuzzy Finder for Kubernetes

Usage: fzfk <resource> [kubectl get args...]

Examples:
  fzfk pods
  fzfk pods -A
  fzfk pods -n kube-system
  fzfk deployments -l app=foo

Keybindings:
  tab      : mark / unmark a resource (multi-select)
  shift-tab: unmark a resource and move up
  enter    : describe the resource under the cursor
  alt-p    : port-forward (pick port via fzf)
  alt-e    : exec into container (pick container via fzf)
  alt-l    : show container logs (pick container via fzf)
  alt-y    : open YAML manifest in nvim
  alt-d    : delete the marked resources (or the one under the cursor);
             the confirmation offers a force option (--grace-period=0 --force)
  alt-r    : reload the list
  ctrl-p   : toggle preview
  ctrl-d   : half page down
  ctrl-u   : half page up
  ctrl-f   : preview half page down
  ctrl-b   : preview half page up

Mark several resources with tab / shift-tab and press alt-d to delete them all
at once. The list is automatically refreshed every 5 seconds; marks and the
cursor position are preserved across refreshes.
EOF
}

if [[ -z "$1" || "$1" == "-h" || "$1" == "--help" ]]; then
  usage
  exit 0
fi

RESOURCE="$1"
shift
KUBECTL_ARGS=("$@")

# Parse namespace flags from kubectl args, so action handlers can
# operate on the same namespace as the listing.
NAMESPACE=""
ALL_NS=false
i=0
while [[ $i -lt ${#KUBECTL_ARGS[@]} ]]; do
  arg="${KUBECTL_ARGS[$i]}"
  case "$arg" in
    -A|--all-namespaces)
      ALL_NS=true
      ;;
    -n|--namespace)
      i=$((i+1))
      NAMESPACE="${KUBECTL_ARGS[$i]}"
      ;;
    --namespace=*)
      NAMESPACE="${arg#*=}"
      ;;
  esac
  i=$((i+1))
done

# Determine field positions used by the fzf bindings.
#   - With -A / --all-namespaces the kubectl output starts with the
#     NAMESPACE column, so we read it from field {1} and the name from {2}.
#   - Otherwise the namespace is fixed (or "-" for the context default)
#     and the name is the first field.
if $ALL_NS; then
  NS_FIELD="{1}"
  NAME_FIELD="{2}"
elif [[ -n "$NAMESPACE" ]]; then
  NS_FIELD="$NAMESPACE"
  NAME_FIELD="{1}"
else
  NS_FIELD="-"
  NAME_FIELD="{1}"
fi

# Identity fields for --track / --id-nth so marked rows and the cursor survive
# reloads even as volatile columns (STATUS, AGE, ...) change, plus the fixed
# namespace token handed to the delete handler.
#   - With -A the identity is the NAMESPACE + NAME columns (fields 1 and 2) and
#     the per-row namespace comes from the row itself, so the token is "-".
#   - Otherwise the identity is the NAME column (field 1) and the namespace is
#     fixed (or "-" for the context default).
if $ALL_NS; then
  ID_NTH="1,2"
  NS_TOKEN="-"
elif [[ -n "$NAMESPACE" ]]; then
  ID_NTH="1"
  NS_TOKEN="$NAMESPACE"
else
  ID_NTH="1"
  NS_TOKEN="-"
fi

LIST_CMD="kubectl get $RESOURCE ${KUBECTL_ARGS[*]}"

# Interval (seconds) for automatically refreshing the listed resources
# (override via FZFK_REFRESH_INTERVAL).
FZFK_REFRESH_INTERVAL="${FZFK_REFRESH_INTERVAL:-5}"

# Build the per-row preview command (kubectl describe under the cursor).
if $ALL_NS; then
  PREVIEW_CMD="kubectl describe $RESOURCE -n {1} {2}"
elif [[ -n "$NAMESPACE" ]]; then
  PREVIEW_CMD="kubectl describe $RESOURCE -n $NAMESPACE {1}"
else
  PREVIEW_CMD="kubectl describe $RESOURCE {1}"
fi

ACTION="$SCRIPT __action"

clear
fzf \
  --ansi \
  --reverse \
  --height 100% \
  --header-lines=1 \
  --info right \
  --prompt "󱃾 $RESOURCE: " \
  --pointer ">" \
  --marker "󰄲" \
  --multi \
  --track \
  --id-nth "$ID_NTH" \
  --border "rounded" \
  --border-label " 󱃾 $LIST_CMD " \
  --border-label-pos center \
  --bind "ctrl-d:half-page-down" \
  --bind "ctrl-u:half-page-up" \
  --bind "ctrl-f:preview-half-page-down" \
  --bind "ctrl-b:preview-half-page-up" \
  --bind "ctrl-p:toggle-preview" \
  --bind "alt-r:reload-sync($LIST_CMD)" \
  --bind "every($FZFK_REFRESH_INTERVAL):reload-sync($LIST_CMD)" \
  --bind "enter:execute($ACTION describe $RESOURCE $NS_FIELD $NAME_FIELD)" \
  --bind "alt-p:execute($ACTION portforward $RESOURCE $NS_FIELD $NAME_FIELD)" \
  --bind "alt-e:execute($ACTION exec $RESOURCE $NS_FIELD $NAME_FIELD)" \
  --bind "alt-l:execute($ACTION logs $RESOURCE $NS_FIELD $NAME_FIELD)" \
  --bind "alt-y:execute($ACTION yaml $RESOURCE $NS_FIELD $NAME_FIELD)" \
  --bind "alt-d:execute($ACTION delete $RESOURCE $ALL_NS $NS_TOKEN {+})+reload-sync($LIST_CMD)" \
  --preview-window "right:65%" \
  --preview "$PREVIEW_CMD" \
  < <(eval "$LIST_CMD")
