#!/usr/bin/env bash

# fzfvault - Fuzzy Finder for Vault (kv secrets engine)
#
# Usage: fzfvault
#
# Browse, view, create, edit, rename and delete secrets in Vault's kv secrets
# engine (v1 and v2 auto-detected). Secrets are viewed as the plain
# `vault kv get` table and created / edited as JSON files in nvim.
#
# Requires: vault, jq, fzf, nvim (and, for the yank action, pbcopy). Uses the
# ambient VAULT_ADDR / VAULT_TOKEN / VAULT_NAMESPACE that the vault CLI reads.
# Reference: https://developer.hashicorp.com/vault/docs/commands/kv

SCRIPT="$(realpath "$0")"

# Nerd font glyphs used in bash-side prompts / labels. Defined via byte escapes
# so they do not depend on a bash that supports the \u / \U printf escapes.
ICON_VAULT=$'\xef\x80\xa3'      # lock (mount / breadcrumb)
ICON_TRASH=$'\xf3\xb0\xa9\xba'  # trash (delete)
ICON_COPY=$'\xf3\xb0\x86\x8f'   # clipboard (yank)

# ---------- List mode ----------
#
# Renders the entries of one kv path level as tab-delimited rows:
#   <rawname>\t<display>
# The rawname (field 1) stays hidden from the picker (--with-nth 2) but remains
# addressable in bindings via {1}; folders keep their trailing "/" so the enter
# dispatcher and the action handlers can tell folders from secrets. Folders are
# listed before secrets. Called for the initial feed and on every reload as:
#   fzfvault __list <mount> <version> <path>

if [[ "$1" == "__list" ]]; then
  mount="$2"
  path="$4"

  err="$(mktemp)"
  if [[ -n "$path" ]]; then
    out="$(vault kv list -format=json -mount="$mount" "$path" 2>"$err")"
  else
    out="$(vault kv list -format=json -mount="$mount" 2>"$err")"
  fi
  status=$?
  if [[ $status -ne 0 ]]; then
    cat "$err" >&2
    rm -f "$err"
    exit 1
  fi
  rm -f "$err"

  printf '%s' "$out" | jq -r '
    (if type == "array" then . else [] end)
    | map({name: ., folder: (test("/$"))})
    | sort_by([(.folder | not), (.name | ascii_downcase)])
    | .[]
    | .name as $n
    | if .folder
      then $n + "\t" + "\u001b[34m\uf07b " + $n + "\u001b[0m"
      else $n + "\t" + "\u001b[36m\uf084 \u001b[0m" + $n
      end
  '
  exit 0
fi

# ---------- Preview mode ----------
#
# Called from the fzf --preview binding as:
#   fzfvault __preview <mount> <version> <path> <rawname>
# A folder preview lists its children; a secret preview shows the full
# `vault kv get` table (including plaintext values, by design).

if [[ "$1" == "__preview" ]]; then
  mount="$2"
  path="$4"
  rawname="$5"
  [[ -z "$rawname" ]] && exit 0

  if [[ -n "$path" ]]; then
    full="$path/$rawname"
  else
    full="$rawname"
  fi

  if [[ "$rawname" == */ ]]; then
    child="${full%/}"
    vault kv list -format=json -mount="$mount" "$child" 2>/dev/null | jq -r '
      (if type == "array" then . else [] end)
      | "\u001b[34m─── \(length) entries ───\u001b[0m", "",
        (.[])
    '
  else
    vault kv get -mount="$mount" "$full"
  fi
  exit 0
fi

# ---------- Enter dispatcher ----------
#
# enter is a single binding; this handler branches on the trailing "/" of the
# selected rawname: a folder is opened in a nested fzfvault __browse (esc pops back
# up one level), a secret is shown read-only in nvim. Called as:
#   fzfvault __enter <mount> <version> <path> <rawname>

if [[ "$1" == "__enter" ]]; then
  mount="$2"
  version="$3"
  path="$4"
  rawname="$5"
  [[ -z "$rawname" ]] && exit 0

  if [[ "$rawname" == */ ]]; then
    child="${rawname%/}"
    if [[ -n "$path" ]]; then
      newpath="$path/$child"
    else
      newpath="$child"
    fi
    "$SCRIPT" __browse "$mount" "$version" "$newpath"
  else
    if [[ -n "$path" ]]; then
      full="$path/$rawname"
    else
      full="$rawname"
    fi
    vault kv get -mount="$mount" "$full" | nvim -R -
  fi
  exit 0
fi

# ---------- Action handlers ----------
#
# Called recursively from fzf bindings as:
#   fzfvault __action <action> <mount> <version> <path> <rawname>

if [[ "$1" == "__action" ]]; then
  shift
  action="$1"
  mount="$2"
  version="$3"
  path="$4"
  rawname="$5"

  # jq path to the secret's data object depends on the kv version.
  if [[ "$version" == "2" ]]; then
    data_jq='.data.data'
  else
    data_jq='.data'
  fi

  # Full path of the row under the cursor (may be a folder for create/web).
  if [[ -n "$path" && -n "$rawname" ]]; then
    full="$path/$rawname"
  elif [[ -n "$rawname" ]]; then
    full="$rawname"
  else
    full=""
  fi

  case "$action" in
    edit)
      if [[ -z "$rawname" || "$rawname" == */ ]]; then
        echo "Not a secret: ${rawname:-<none>}"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi

      tmp="$(mktemp -d)/data.json"
      if ! vault kv get -format=json -mount="$mount" "$full" 2>/dev/null \
        | jq "$data_jq" > "$tmp"; then
        rm -rf "${tmp%/*}"
        echo "Could not read $mount/$full"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi
      orig="$(cat "$tmp")"
      nvim "$tmp"

      if [[ "$(cat "$tmp")" == "$orig" ]]; then
        rm -rf "${tmp%/*}"
        exit 0
      fi
      if ! jq empty "$tmp" 2>"${tmp%/*}/jq.err"; then
        echo "Invalid JSON, not writing to Vault:"
        cat "${tmp%/*}/jq.err"
        rm -rf "${tmp%/*}"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi
      if ! jq -e 'type == "object" and length > 0' "$tmp" >/dev/null; then
        echo "Secret data must be a non-empty JSON object."
        rm -rf "${tmp%/*}"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi

      if ! vault kv put -mount="$mount" "$full" @"$tmp"; then
        read -n 1 -s -r -p "Press any key to continue..."
      fi
      rm -rf "${tmp%/*}"
      ;;

    create)
      # macOS ships bash 3.2, which lacks `read -i` for a prefilled prompt, so
      # the box is an fzf query seeded with the current folder over an empty
      # candidate list: type the leaf name, Enter accepts, Esc cancels.
      newfull="$(fzf --print-query --query "${path:+$path/}" \
        --prompt "New secret (relative to $mount/): " \
        --height 100% \
        --reverse \
        --border rounded \
        --border-label " $ICON_VAULT new secret in $mount/${path:+$path/} " \
        --border-label-pos center \
        --header "Type the path, then Enter (Esc to cancel)" \
        < /dev/null)"
      rc=$?
      # 0 = match accepted, 1 = query accepted (no match); anything else (130
      # Esc, 2 error) means cancel.
      [[ $rc -ne 0 && $rc -ne 1 ]] && exit 0
      newfull="$(printf '%s\n' "$newfull" | head -1)"
      newfull="${newfull#/}"
      if [[ -z "$newfull" || "$newfull" == */ ]]; then
        exit 0
      fi

      tmp="$(mktemp -d)/data.json"
      printf '{}\n' > "$tmp"
      nvim "$tmp"

      if ! jq empty "$tmp" 2>"${tmp%/*}/jq.err"; then
        echo "Invalid JSON, not writing to Vault:"
        cat "${tmp%/*}/jq.err"
        rm -rf "${tmp%/*}"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi
      if ! jq -e 'type == "object" and length > 0' "$tmp" >/dev/null; then
        echo "Secret data must be a non-empty JSON object; aborting."
        rm -rf "${tmp%/*}"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi

      if ! vault kv put -mount="$mount" "$newfull" @"$tmp"; then
        read -n 1 -s -r -p "Press any key to continue..."
      fi
      rm -rf "${tmp%/*}"
      ;;

    rename)
      if [[ -z "$rawname" || "$rawname" == */ ]]; then
        echo "Not a secret: ${rawname:-<none>}"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi

      # Vault has no native rename: read the source, write it to the new path
      # and only then remove the old one. The edit box is prefilled with the
      # current full path (relative to the mount root); editing the folder part
      # moves the secret. Empty or unchanged input aborts.
      #
      # macOS ships bash 3.2, which lacks `read -i` for a prefilled prompt, so
      # the box is an fzf query seeded with the current path over an empty
      # candidate list: Enter prints the (edited) query, Esc cancels.
      newrel="$(fzf --print-query --query "$full" \
        --prompt "Rename to (relative to $mount/): " \
        --height 100% \
        --reverse \
        --border rounded \
        --border-label " $ICON_VAULT rename $mount/$full " \
        --border-label-pos center \
        --header "Edit the path, then Enter (Esc to cancel)" \
        < /dev/null)"
      rc=$?
      # 0 = match accepted, 1 = query accepted (no match); anything else (130
      # Esc, 2 error) means cancel.
      if [[ $rc -ne 0 && $rc -ne 1 ]]; then
        exit 0
      fi
      newrel="$(printf '%s\n' "$newrel" | head -1)"
      newrel="${newrel#/}"
      if [[ -z "$newrel" || "$newrel" == "$full" ]]; then
        exit 0
      fi
      if [[ "$newrel" == */ ]]; then
        echo "Target must be a secret path, not a folder: $newrel"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi

      # Refuse to clobber an existing secret at the target path. For v2 the
      # metadata path is what matters (a soft-deleted secret still occupies it).
      if [[ "$version" == "2" ]]; then
        exists_cmd=(vault kv metadata get -mount="$mount" "$newrel")
      else
        exists_cmd=(vault kv get -mount="$mount" "$newrel")
      fi
      if "${exists_cmd[@]}" >/dev/null 2>&1; then
        echo "Target already exists: $mount/$newrel"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi

      # Read the source secret's latest data.
      data="$(vault kv get -format=json -mount="$mount" "$full" 2>/dev/null | jq "$data_jq")"
      if [[ -z "$data" || "$data" == "null" ]]; then
        echo "Could not read $mount/$full"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi
      if ! printf '%s' "$data" | jq -e 'type == "object" and length > 0' >/dev/null; then
        echo "Source secret has no data to move: $mount/$full"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi

      # Reproduce the source metadata at the target (v2 only): custom_metadata
      # plus the per-secret config max_versions / cas_required /
      # delete_version_after.
      meta_args=()
      if [[ "$version" == "2" ]]; then
        meta="$(vault kv metadata get -format=json -mount="$mount" "$full" 2>/dev/null | jq '.data')"
        if [[ -n "$meta" && "$meta" != "null" ]]; then
          meta_args+=(
            "-max-versions=$(printf '%s' "$meta" | jq -r '.max_versions // 0')"
            "-cas-required=$(printf '%s' "$meta" | jq -r '.cas_required // false')"
            "-delete-version-after=$(printf '%s' "$meta" | jq -r '.delete_version_after // "0s"')"
          )
          while IFS= read -r cm; do
            [[ -n "$cm" ]] && meta_args+=("-custom-metadata=$cm")
          done < <(printf '%s' "$meta" | jq -r '(.custom_metadata // {}) | to_entries[] | "\(.key)=\(.value)"')
        fi
      fi

      # Write the data to the new path first; the old path is only removed once
      # every write has succeeded, so a failure never loses the secret.
      tmp="$(mktemp -d)/data.json"
      printf '%s' "$data" > "$tmp"
      if ! vault kv put -mount="$mount" "$newrel" @"$tmp"; then
        rm -rf "${tmp%/*}"
        echo "Failed to write $mount/$newrel; $mount/$full left unchanged."
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi
      rm -rf "${tmp%/*}"

      if [[ "$version" == "2" && ${#meta_args[@]} -gt 0 ]]; then
        if ! vault kv metadata put -mount="$mount" "${meta_args[@]}" "$newrel"; then
          echo "Wrote data but failed to set metadata on $mount/$newrel;"
          echo "$mount/$full left unchanged. Resolve before retrying."
          read -n 1 -s -r -p "Press any key to continue..."
          exit 0
        fi
      fi

      # New path is fully written; remove the old one (permanently for v2, to
      # match the delete action so no orphaned metadata/versions remain).
      if [[ "$version" == "2" ]]; then
        if ! vault kv metadata delete -mount="$mount" "$full"; then
          echo "New secret is at $mount/$newrel but removing $mount/$full failed."
          read -n 1 -s -r -p "Press any key to continue..."
        fi
      else
        if ! vault kv delete -mount="$mount" "$full"; then
          echo "New secret is at $mount/$newrel but removing $mount/$full failed."
          read -n 1 -s -r -p "Press any key to continue..."
        fi
      fi
      ;;

    delete)
      if [[ -z "$rawname" || "$rawname" == */ ]]; then
        echo "Not a secret: ${rawname:-<none>}"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi

      confirm="$(printf '%s\n' "No" "Yes" | fzf \
        --bind "ctrl-d:half-page-down" \
        --bind "ctrl-u:half-page-up" \
        --prompt "$ICON_TRASH Permanently delete $mount/$full: " \
        --height 100% \
        --reverse \
        --border rounded)"
      [[ "$confirm" != "Yes" ]] && exit 0

      if [[ "$version" == "2" ]]; then
        if ! vault kv metadata delete -mount="$mount" "$full"; then
          read -n 1 -s -r -p "Press any key to continue..."
        fi
      else
        if ! vault kv delete -mount="$mount" "$full"; then
          read -n 1 -s -r -p "Press any key to continue..."
        fi
      fi
      ;;

    yank)
      if [[ -z "$rawname" || "$rawname" == */ ]]; then
        echo "Not a secret: ${rawname:-<none>}"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi

      data="$(vault kv get -format=json -mount="$mount" "$full" 2>/dev/null | jq "$data_jq")"
      if [[ -z "$data" || "$data" == "null" ]]; then
        echo "Could not read $mount/$full"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi

      key="$(printf '%s' "$data" | jq -r 'keys[]' | fzf \
        --bind "ctrl-d:half-page-down" \
        --bind "ctrl-u:half-page-up" \
        --prompt "$ICON_COPY Yank field ($rawname): " \
        --height 100% \
        --reverse \
        --border rounded)"
      [[ -z "$key" ]] && exit 0

      printf '%s' "$data" \
        | jq -rj --arg k "$key" '.[$k] | if type == "string" then . else tojson end' \
        | pbcopy
      ;;

    web)
      [[ -z "$rawname" ]] && exit 0
      addr="${VAULT_ADDR%/}"
      if [[ -z "$addr" ]]; then
        echo "VAULT_ADDR is not set."
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi
      # The Vault UI expects the mount and secret paths URL-encoded (slashes as
      # %2F); @uri leaves the unreserved characters (incl. "-") untouched.
      enc_mount="$(jq -rn --arg s "$mount" '$s | @uri')"
      if [[ "$rawname" == */ ]]; then
        enc_path="$(jq -rn --arg s "${full%/}" '$s | @uri')"
        open "$addr/ui/vault/secrets-engines/$enc_mount/kv/$enc_path/"
      else
        enc_path="$(jq -rn --arg s "$full" '$s | @uri')"
        open "$addr/ui/vault/secrets-engines/$enc_mount/kv/$enc_path"
      fi
      ;;

    *)
      echo "Unknown action: $action"
      exit 1
      ;;
  esac
  exit 0
fi

# ---------- Browse mode ----------
#
# One nested fzf per kv path level. Called as:
#   fzfvault __browse <mount> <version> <path>
# esc exits this level and returns to the parent level (or the mount picker at
# the root).

if [[ "$1" == "__browse" ]]; then
  mount="$2"
  version="$3"
  path="$4"

  ROWS="$("$SCRIPT" __list "$mount" "$version" "$path")" || exit 1
  if [[ -z "$ROWS" ]]; then
    echo "No secrets under $mount/${path:+$path/}"
    read -n 1 -s -r -p "Press any key to continue..."
    exit 0
  fi

  ENTER="$SCRIPT __enter '$mount' '$version' '$path'"
  ACTION="$SCRIPT __action"
  LIST="$SCRIPT __list '$mount' '$version' '$path'"
  PREVIEW="$SCRIPT __preview '$mount' '$version' '$path' {1}"

  clear
  printf '%s\n' "$ROWS" | fzf \
    --ansi \
    --delimiter $'\t' \
    --with-nth 2 \
    --reverse \
    --height 100% \
    --info right \
    --prompt "$ICON_VAULT $mount/${path:+$path/}: " \
    --pointer ">" \
    --border "rounded" \
    --border-label " $ICON_VAULT $mount/$path (v$version) " \
    --border-label-pos center \
    --bind "ctrl-d:half-page-down" \
    --bind "ctrl-u:half-page-up" \
    --bind "ctrl-f:preview-half-page-down" \
    --bind "ctrl-b:preview-half-page-up" \
    --bind "ctrl-p:toggle-preview" \
    --bind "alt-r:reload($LIST)" \
    --bind "enter:execute($ENTER {1})+reload($LIST)+refresh-preview" \
    --bind "alt-e:execute($ACTION edit '$mount' '$version' '$path' {1})+reload($LIST)+refresh-preview" \
    --bind "alt-n:execute($ACTION create '$mount' '$version' '$path' {1})+reload($LIST)" \
    --bind "alt-m:execute($ACTION rename '$mount' '$version' '$path' {1})+reload($LIST)+refresh-preview" \
    --bind "alt-d:execute($ACTION delete '$mount' '$version' '$path' {1})+reload($LIST)+refresh-preview" \
    --bind "alt-y:execute($ACTION yank '$mount' '$version' '$path' {1})" \
    --bind "alt-o:execute($ACTION web '$mount' '$version' '$path' {1})" \
    --preview-window "right:65%" \
    --preview "$PREVIEW"
  exit 0
fi

# ---------- Main mode (mount picker) ----------

usage() {
  cat <<'EOF'
fzfvault - Fuzzy Finder for Vault (kv secrets engine)

Usage: fzfvault

Starts with a picker of the kv secrets engines (v1 and v2 are auto-detected),
then opens a drill-down browser of that mount's paths. Folders are listed with
a trailing "/"; enter descends into a folder or opens a secret.

Keybindings (browser):
  enter   : open a folder (descend) or view a secret (opens read-only in nvim)
  alt-e   : edit the secret (data JSON in nvim; full overwrite on save)
  alt-n   : create a new secret (path relative to the current folder)
  alt-m   : rename / move the secret (within the same mount)
  alt-d   : delete the secret permanently (after confirmation)
  alt-y   : yank one field's value to the clipboard (pbcopy)
  alt-o   : open the secret / folder in the Vault web UI
  alt-r   : reload the current level
  esc     : go up one level (at the root, back to the mount picker)
  ctrl-p  : toggle preview
  ctrl-d  : half page down
  ctrl-u  : half page up
  ctrl-f  : preview half page down
  ctrl-b  : preview half page up

The preview shows a folder's children, or a secret's full `vault kv get` table
(including plaintext values). Viewing a secret (enter) shows the same table
read-only in nvim. Edits and new secrets are the data-only JSON object; on save
the JSON is validated with jq and, if valid and non-empty, written back with
`vault kv put`. Delete is permanent: `vault kv metadata delete` for v2 (removes
all versions) and `vault kv delete` for v1.

Rename/move (alt-m) has no native Vault equivalent, so it copies the secret to
the new path and then removes the old one; the old path is only deleted once
every write succeeds, so a failure never loses data. For v2 the latest data is
copied along with its custom_metadata and per-secret config (max_versions,
cas_required, delete_version_after); older versions are not carried over.
Renaming into another folder moves the secret; an existing target is never
overwritten. Moves stay within the same mount.

Environment:
  VAULT_ADDR      Vault server address (used by the vault CLI and the web UI).
  VAULT_TOKEN     Vault token (or ~/.vault-token, as the vault CLI reads it).
  VAULT_NAMESPACE Vault namespace (Enterprise / HCP), honoured by the vault CLI.
  FZFVAULT_MOUNTS Override mount discovery when the token cannot enumerate
                  mounts (needs sys/mounts read otherwise). Comma-separated
                  "name:version" pairs, e.g. "secret:2,kv:1". Version defaults
                  to 2 when omitted.
EOF
}

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  usage
  exit 0
fi

# Build the mount rows: "<mount>\t<version>\t<display>". From FZFVAULT_MOUNTS when
# set, otherwise from `vault secrets list` filtered to kv mounts (which also
# doubles as the auth / connectivity preflight).
if [[ -n "$FZFVAULT_MOUNTS" ]]; then
  # Comma-separated "name:version" pairs; version defaults to 2 when omitted.
  # Rendered through jq (like the secrets-list branch) so the ANSI / glyph
  # escapes do not depend on a bash that supports the \u / \x printf escapes.
  MOUNT_ROWS="$(jq -rn --arg s "$FZFVAULT_MOUNTS" '
    ($s | split(",")
      | map(gsub("^\\s+|\\s+$"; "")) | map(select(length > 0))
      | map(split(":") | { name: (.[0] | sub("/$"; "")), version: (.[1] // "2") }))
    | .[]
    | .name + "\t" + .version + "\t"
      + "\u001b[34m\uf023 \u001b[0m" + .name + "  \u001b[90m(v" + .version + ")\u001b[0m"
  ')"
else
  err="$(mktemp)"
  MOUNT_ROWS="$(vault secrets list -format=json 2>"$err" | jq -r '
    to_entries
    | map(select(.value.type == "kv"))
    | sort_by(.key)
    | .[]
    | (.key | sub("/$"; "")) as $m
    | (.value.options.version // "1") as $v
    | $m + "\t" + $v + "\t"
      + "\u001b[34m\uf023 \u001b[0m" + $m + "  \u001b[90m(v" + $v + ")\u001b[0m"
  ')"
  status=${PIPESTATUS[0]}
  if [[ $status -ne 0 ]]; then
    cat "$err" >&2
    rm -f "$err"
    exit 1
  fi
  rm -f "$err"
fi

if [[ -z "$MOUNT_ROWS" ]]; then
  echo "No kv secrets engines found." >&2
  exit 1
fi

# Loop the mount picker so esc from the root browse returns here; esc from the
# picker itself exits fzfvault.
while true; do
  clear
  sel="$(printf '%s\n' "$MOUNT_ROWS" | fzf \
    --bind "ctrl-d:half-page-down" \
    --bind "ctrl-u:half-page-up" \
    --ansi \
    --delimiter $'\t' \
    --with-nth 3 \
    --reverse \
    --height 100% \
    --info right \
    --prompt "$ICON_VAULT Mount: " \
    --pointer ">" \
    --border "rounded" \
    --border-label " $ICON_VAULT Vault kv mounts " \
    --border-label-pos center)"
  [[ -z "$sel" ]] && break

  mount="$(printf '%s' "$sel" | cut -f1)"
  version="$(printf '%s' "$sel" | cut -f2)"
  [[ -z "$mount" ]] && break

  "$SCRIPT" __browse "$mount" "$version" ""
done
