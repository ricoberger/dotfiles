#!/usr/bin/env bash

# fzfjira - Fuzzy Finder for Jira (acli)
#
# Usage: fzfjira [JQL]
#
# Requires: acli jira auth login --web
# Reference: https://developer.atlassian.com/cloud/acli/reference/commands/jira/

SCRIPT="$(realpath "$0")"

# Status names offered by the transition picker (override via FZFJIRA_STATUSES).
if [[ -z "$FZFJIRA_STATUSES" ]]; then
  FZFJIRA_STATUSES="Open,Backlog,Ready for Implementation,In Progress,In Review,Delivery,Discovery,On Hold,Done,Won't do"
fi
# Maximum number of work items to fetch (override via FZFJIRA_LIMIT).
FZFJIRA_LIMIT="${FZFJIRA_LIMIT:-250}"
# Project used when creating new work items (override via FZFJIRA_PROJECT).
FZFJIRA_PROJECT="${FZFJIRA_PROJECT:-CORE}"
# Custom field id backing the "Flagged" field, used by the flag action and the
# preview indicator (override via FZFJIRA_FLAG_FIELD). customfield_10002 is the
# standard Jira Software "Flagged" field on most sites.
FZFJIRA_FLAG_FIELD="${FZFJIRA_FLAG_FIELD:-customfield_10002}"

# Named JQL filters shown in a picker when fzfjira is launched without a JQL
# argument. Each entry is "Name|JQL". Override the whole list at runtime via
# the FZFJIRA_FILTERS env var (newline-separated "Name|JQL" entries); otherwise
# these baked defaults are used.
FZFJIRA_DEFAULT_FILTERS=(
  "Board|project = CORE AND statusCategory != Done AND status != \"Backlog\" AND issuetype != \"Sub-Task\" AND issuetype != \"Epic\" ORDER BY updated DESC"
  "Assigned|project = CORE AND assignee = currentUser() AND statusCategory != Done AND status != Backlog ORDER BY priority DESC, updated DESC"
  "Backlog|project = CORE AND status = \"Backlog\" AND issuetype != \"Sub-Task\" AND issuetype != \"Epic\" ORDER BY created DESC"
)

# Link types offered by the link-create picker. Each entry is
# "Label|TypeName|direction" where direction is "out" (the selected work item
# is the outward/source side) or "in" (the selected work item is the inward
# side). The stable TypeName is passed to acli; the direction decides which
# work item becomes --out and which becomes --in. Override the whole list at
# runtime via the FZFJIRA_LINK_TYPES env var (newline-separated entries).
FZFJIRA_DEFAULT_LINK_TYPES=(
  "blocks|Blocks|out"
  "is blocked by|Blocks|in"
  "relates to|Relates|out"
  "duplicates|Duplicate|out"
  "is duplicated by|Duplicate|in"
  "clones|Cloners|out"
  "is cloned by|Cloners|in"
  "tests|Tests|out"
  "is tested by|Tests|in"
)

# ---------- acli OAuth helpers ----------
#
# acli cannot edit some fields (e.g. a work item's parent/Epic — no --parent on
# edit and --from-json rejects it — or the Flagged field), so the `epic` and
# `flag` actions talk to the Jira REST API directly, reusing the OAuth token
# acli stored in the macOS keychain.

# Print acli's current Jira profile ("<cloud_id>:<account_id>"), read from
# acli's config. The cloud_id (part before the first colon) is used to build
# REST URLs; the whole string is the keychain account suffix.
fzfjira_jira_profile() {
  sed -n 's/^current_profile:[[:space:]]*//p' \
    "${HOME}/.config/acli/jira_config.yaml" 2>/dev/null \
    | tr -d '"' | head -n1
}

# Print acli's current OAuth access token, extracted from the macOS keychain.
# The value is stored by go-keyring as "go-keyring-base64:<base64(gzip(json))>".
fzfjira_jira_token() {
  local profile="$1"
  security find-generic-password -s acli -a "jira:${profile}" -w 2>/dev/null \
    | sed 's/^go-keyring-base64://' \
    | base64 -d 2>/dev/null \
    | gunzip 2>/dev/null \
    | jq -r '.access_token // empty'
}

# PUT a partial field update to a work item via the Jira REST API, using acli's
# keychain OAuth token. Args: <key> <json-body>. Returns 0 and prints nothing
# on success (HTTP 204); on any error prints a message, waits for a keypress,
# and returns 1.
fzfjira_jira_put() {
  local key="$1" data="$2"
  local profile cloud_id token resp code body

  profile="$(fzfjira_jira_profile)"
  cloud_id="${profile%%:*}"
  if [[ -z "$profile" || -z "$cloud_id" ]]; then
    echo "Could not determine the acli Jira profile."
    echo "Have you run 'acli jira auth login --web'?"
    read -n 1 -s -r -p "Press any key to continue..."
    return 1
  fi

  # acli keeps the keychain token fresh through normal use; a stale one
  # surfaces as HTTP 401 below.
  token="$(fzfjira_jira_token "$profile")"
  if [[ -z "$token" ]]; then
    echo "Could not read the acli OAuth token from the keychain."
    read -n 1 -s -r -p "Press any key to continue..."
    return 1
  fi

  resp="$(curl -s --max-time 30 -w '\n%{http_code}' -X PUT \
    -H "Authorization: Bearer $token" \
    -H "Content-Type: application/json" \
    "https://api.atlassian.com/ex/jira/$cloud_id/rest/api/3/issue/$key" \
    --data "$data")"
  code="$(printf '%s' "$resp" | tail -n1)"
  body="$(printf '%s' "$resp" | sed '$d')"

  if [[ "$code" == "204" ]]; then
    return 0
  elif [[ "$code" == "401" ]]; then
    echo "Unauthorized (HTTP 401). Re-authenticate with 'acli jira auth login --web'."
  else
    echo "Request failed (HTTP $code)."
    [[ -n "$body" ]] && printf '%s\n' "$body"
  fi
  read -n 1 -s -r -p "Press any key to continue..."
  return 1
}

# ---------- List mode ----------
#
# Called for the initial feed and on every reload. Reads the JQL from the
# environment (FZFJIRA_JQL) so the fzf reload binding stays quoting-safe.

if [[ "$1" == "__list" ]]; then
  # An optional second argument overrides FZFJIRA_JQL (used by the link-create
  # target picker to feed a project-wide query through the same renderer).
  list_jql="${2:-$FZFJIRA_JQL}"
  err="$(mktemp)"
  out="$(acli jira workitem search \
    --jql "$list_jql" \
    --limit "$FZFJIRA_LIMIT" \
    --json 2>"$err")"
  status=$?

  if [[ $status -ne 0 ]]; then
    cat "$err" >&2
    rm -f "$err"
    exit 1
  fi
  rm -f "$err"

  printf '%s' "$out" | jq -r '
    def pad(s; n): (s + (" " * 60))[0:n];
    def color(c):
      {
        green: "32",
        yellow: "33",
        "blue-gray": "34",
        brown: "33",
        "medium-gray": "37",
        "warm-red": "31"
      }[c] // "37";
    .[]
    | (.fields.status.statusCategory.colorName // "medium-gray") as $c
    | pad(.key; 12) + " "
      + "\u001b[" + color($c) + "m" + pad((.fields.status.name // "-"); 14) + "\u001b[0m" + " "
      + (.fields.summary // "-" | gsub("[\t\n\r]"; " "))
  '
  exit 0
fi

# ---------- Preview mode ----------
#
# Renders the work item details followed by its comment thread. Called from
# the fzf --preview binding as: fzfjira __preview <key>

if [[ "$1" == "__preview" ]]; then
  key="$2"
  [[ -z "$key" ]] && exit 0

  acli jira workitem view "$key" --fields "*all"

  flagged="$(acli jira workitem view "$key" --fields "$FZFJIRA_FLAG_FIELD" --json 2>/dev/null)"
  if [[ -n "$flagged" ]]; then
    printf '%s' "$flagged" | jq -r --arg ff "$FZFJIRA_FLAG_FIELD" '
      (.fields[$ff] // []) as $f
      | if ($f | length) == 0 then empty
        else "", "\u001b[31m󰈻 Flagged (\($f | map(.value) | join(", ")))\u001b[0m"
        end
    '
  fi

  parent="$(acli jira workitem view "$key" --fields parent --json 2>/dev/null)"
  if [[ -n "$parent" ]]; then
    printf '%s' "$parent" | jq -r '
      def pad(s; n): (s + (" " * 60))[0:n];
      def color(c):
        {
          green: "32",
          yellow: "33",
          "blue-gray": "34",
          brown: "33",
          "medium-gray": "37",
          "warm-red": "31"
        }[c] // "37";
      (.fields.parent // empty) as $p
      | if ($p | not) then empty
        else
          ($p.fields.issuetype.name // "Parent") as $t
          | ($p.fields.status.statusCategory.colorName // "medium-gray") as $c
          | "",
            "─── \($t) ───",
            "",
            "  " + pad(($p.key // "-"); 12) + " "
              + "\u001b[" + color($c) + "m" + pad(($p.fields.status.name // "-"); 14) + "\u001b[0m" + " "
              + (($p.fields.summary // "-") | gsub("[\t\n\r]"; " "))
        end
    '
  fi

  subtasks="$(acli jira workitem view "$key" --fields subtasks --json 2>/dev/null)"
  if [[ -n "$subtasks" ]]; then
    printf '%s' "$subtasks" | jq -r '
      def pad(s; n): (s + (" " * 60))[0:n];
      def color(c):
        {
          green: "32",
          yellow: "33",
          "blue-gray": "34",
          brown: "33",
          "medium-gray": "37",
          "warm-red": "31"
        }[c] // "37";
      (.fields.subtasks // []) as $subs
      | if ($subs | length) == 0 then empty
        else
          "",
          "─── Sub-tasks (\($subs | length)) ───",
          "",
          ($subs[]
            | (.fields.status.statusCategory.colorName // "medium-gray") as $c
            | "  " + pad((.key // "-"); 12) + " "
              + "\u001b[" + color($c) + "m" + pad((.fields.status.name // "-"); 14) + "\u001b[0m" + " "
              + ((.fields.summary // "-") | gsub("[\t\n\r]"; " "))
          )
        end
    '
  fi

  links="$(acli jira workitem view "$key" --fields issuelinks --json 2>/dev/null)"
  if [[ -n "$links" ]]; then
    echo
    printf '%s' "$links" | jq -r '
      def pad(s; n): (s + (" " * 60))[0:n];
      def color(c):
        {
          green: "32",
          yellow: "33",
          "blue-gray": "34",
          brown: "33",
          "medium-gray": "37",
          "warm-red": "31"
        }[c] // "37";
      (.fields.issuelinks // []) as $links
      | "─── Links (\($links | length)) ───",
        "",
        ($links[]
          | select(.outwardIssue or .inwardIssue)
          | (if .outwardIssue
             then {dir: (.type.outward // .type.name), iss: .outwardIssue}
             else {dir: (.type.inward // .type.name), iss: .inwardIssue} end) as $l
          | ($l.iss.fields.status.statusCategory.colorName // "medium-gray") as $c
          | "  " + pad(($l.dir // "-"); 16) + " "
            + pad(($l.iss.key // "-"); 12) + " "
            + "\u001b[" + color($c) + "m" + pad(($l.iss.fields.status.name // "-"); 14) + "\u001b[0m" + " "
            + (($l.iss.fields.summary // "-") | gsub("[\t\n\r]"; " "))
        )
    '
  fi

  comments="$(acli jira workitem comment list --key "$key" --json 2>/dev/null)"
  if [[ -n "$comments" ]]; then
    echo
    printf '%s' "$comments" | jq -r '
      "─── Comments (\(.total // 0)) ───",
      "",
      (.comments[]?
        | "▌ \(.author)",
          ((.body // "") | gsub("\r"; "") | split("\n")[] | "  " + .),
          ""
      )
    '
  fi
  exit 0
fi

# ---------- Action handlers ----------
#
# Called recursively from fzf bindings as:
#   fzfjira __action <action> <key>

if [[ "$1" == "__action" ]]; then
  shift
  action="$1"
  key="$2"

  if [[ "$action" != "create" && -z "$key" ]]; then
    exit 0
  fi

  case "$action" in
    view)
      acli jira workitem view "$key" --fields "*all" | nvim -R -
      ;;

    web)
      acli jira workitem view "$key" --web >/dev/null 2>&1
      ;;

    subtasks)
      # Drill into an issue's sub-tasks in a nested picker so that every normal
      # action (transition, assign, comment, edit, link, …) is available for
      # them. Relaunches the script with a `parent = <key>` JQL, which reuses
      # the whole main mode (list + bindings). No-op when there are none.
      count="$(acli jira workitem view "$key" --fields subtasks --json 2>/dev/null \
        | jq -r '(.fields.subtasks // []) | length')"
      if [[ -z "$count" || "$count" == "0" ]]; then
        echo "No sub-tasks for $key"
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi
      "$SCRIPT" "parent = $key ORDER BY created ASC"
      ;;

    assign)
      choice=$(printf '%s\n' "@me" "default" "remove assignee" "custom…" | fzf \
        --prompt "󰋐 Assign $key: " \
        --height 100% \
        --reverse \
        --border rounded)
      [[ -z "$choice" ]] && exit 0

      assign_args=(--key "$key" --yes)
      case "$choice" in
        "@me")             assign_args+=(--assignee "@me") ;;
        "default")         assign_args+=(--assignee "default") ;;
        "remove assignee") assign_args+=(--remove-assignee) ;;
        "custom…")
          # macOS ships bash 3.2, which lacks `read -i` for a prefilled prompt,
          # so the box is an fzf query over an empty candidate list: type the
          # value, Enter accepts, Esc cancels.
          email="$(fzf --print-query --query "" \
            --prompt "󰋐 Assignee (email or account ID): " \
            --height 100% \
            --reverse \
            --border rounded \
            --border-label " 󰋐 assign $key " \
            --border-label-pos center \
            --header "Type the assignee, then Enter (Esc to cancel)" \
            < /dev/null)"
          rc=$?
          # 0 = match accepted, 1 = query accepted (no match); anything else
          # (130 Esc, 2 error) means cancel.
          [[ $rc -ne 0 && $rc -ne 1 ]] && exit 0
          email="$(printf '%s\n' "$email" | head -1)"
          [[ -z "$email" ]] && exit 0
          assign_args+=(--assignee "$email")
          ;;
      esac

      if ! acli jira workitem assign "${assign_args[@]}"; then
        read -n 1 -s -r -p "Press any key to continue..."
      fi
      ;;

    transition)
      status=$(printf '%s' "$FZFJIRA_STATUSES" | tr ',' '\n' | sed 's/^ *//;s/ *$//' | awk 'NF' | fzf \
        --prompt "󰒍 Transition $key: " \
        --height 100% \
        --reverse \
        --border rounded)
      [[ -z "$status" ]] && exit 0

      if ! acli jira workitem transition --key "$key" --status "$status" --yes; then
        read -n 1 -s -r -p "Press any key to continue..."
      fi
      ;;

    comment)
      if ! acli jira workitem comment create --key "$key" --editor; then
        read -n 1 -s -r -p "Press any key to continue..."
      fi
      ;;

    edit)
      field=$(printf '%s\n' "Type" "Summary" "Description" | fzf \
        --prompt "󰏫 Edit $key: " \
        --height 100% \
        --reverse \
        --border rounded)
      [[ -z "$field" ]] && exit 0

      case "$field" in
        Type)
          new_type=$(acli jira project view --key "$FZFJIRA_PROJECT" --json 2>/dev/null \
            | jq -r '(if type == "array" then .[0] else . end)
                     | .issueTypes[] | select(.subtask | not) | .name' \
            | fzf \
                --prompt "󰜢 Type ($key): " \
                --height 100% \
                --reverse \
                --border rounded)
          [[ -z "$new_type" ]] && exit 0
          if ! acli jira workitem edit --key "$key" --type "$new_type" --yes; then
            read -n 1 -s -r -p "Press any key to continue..."
          fi
          ;;

        Summary)
          tmp="$(mktemp)"
          acli jira workitem view "$key" --fields "summary" --json 2>/dev/null \
            | jq -r '.fields.summary // ""' > "$tmp"
          orig="$(cat "$tmp")"
          nvim "$tmp"
          IFS= read -r new_summary < "$tmp"
          rm -f "$tmp"
          if [[ -z "$new_summary" || "$new_summary" == "$orig" ]]; then
            exit 0
          fi
          if ! acli jira workitem edit --key "$key" --summary "$new_summary" --yes; then
            read -n 1 -s -r -p "Press any key to continue..."
          fi
          ;;

        Description)
          tmp="$(mktemp)"
          acli jira workitem view "$key" --fields "description" --json 2>/dev/null | jq -r '
            def toText:
              if type == "object" then
                if .type == "text" then (.text // "")
                elif .type == "hardBreak" then "\n"
                elif .type == "inlineCard" then (.attrs.url // .attrs.data.url // "")
                elif .type == "mention" then (.attrs.text // "")
                elif (.type == "paragraph" or .type == "heading") then ((.content // [] | map(toText) | join("")) + "\n")
                elif .type == "listItem" then ("- " + (.content // [] | map(toText) | join("")))
                elif .content then (.content | map(toText) | join(""))
                else "" end
              elif type == "array" then (map(toText) | join(""))
              else "" end;
            (.fields.description // empty) | toText
          ' > "$tmp"
          orig="$(cat "$tmp")"
          nvim "$tmp"
          if [[ "$(cat "$tmp")" == "$orig" ]]; then
            rm -f "$tmp"
            exit 0
          fi
          if ! acli jira workitem edit --key "$key" --description-file "$tmp" --yes; then
            read -n 1 -s -r -p "Press any key to continue..."
          fi
          rm -f "$tmp"
          ;;
      esac
      ;;

    epic)
      # Set / change the work item's parent Epic. acli can't do this, so this
      # calls the Jira REST API directly with acli's keychain OAuth token.

      # Pick a target Epic from the project (reusing the list renderer).
      epic_rows="$("$SCRIPT" __list "project = $FZFJIRA_PROJECT AND issuetype = Epic AND statusCategory != Done ORDER BY updated DESC" 2>/dev/null)"
      if [[ -z "$epic_rows" ]]; then
        echo "No open Epics found in project $FZFJIRA_PROJECT."
        read -n 1 -s -r -p "Press any key to continue..."
        exit 0
      fi

      esel="$(printf '%s\n' "$epic_rows" | fzf \
        --ansi \
        --prompt "󰜢 Epic $key: " \
        --header "KEY          STATUS         SUMMARY" \
        --height 100% \
        --reverse \
        --border rounded)"
      [[ -z "$esel" ]] && exit 0
      epic="$(printf '%s' "$esel" | awk '{print $1}')"
      [[ -z "$epic" ]] && exit 0

      fzfjira_jira_put "$key" "{\"fields\":{\"parent\":{\"key\":\"$epic\"}}}"
      ;;

    flag)
      # Add / remove the "Flagged" (Impediment) marker. acli can't edit this
      # field, so this calls the Jira REST API directly.
      choice=$(printf '%s\n' "Flag (Impediment)" "Unflag" | fzf \
        --prompt "󰈻 Flag $key: " \
        --height 100% \
        --reverse \
        --border rounded)
      [[ -z "$choice" ]] && exit 0

      case "$choice" in
        "Flag (Impediment)")
          fzfjira_jira_put "$key" "{\"fields\":{\"$FZFJIRA_FLAG_FIELD\":[{\"value\":\"Impediment\"}]}}"
          ;;
        "Unflag")
          fzfjira_jira_put "$key" "{\"fields\":{\"$FZFJIRA_FLAG_FIELD\":[]}}"
          ;;
      esac
      ;;

    create)
      project="$FZFJIRA_PROJECT"

      type=$(acli jira project view --key "$project" --json 2>/dev/null \
        | jq -r '(if type == "array" then .[0] else . end)
                 | .issueTypes[] | select(.subtask | not) | .name' \
        | fzf \
            --prompt "󰜢 Type ($project): " \
            --height 100% \
            --reverse \
            --border rounded)
      [[ -z "$type" ]] && exit 0

      # macOS ships bash 3.2, which lacks `read -i` for a prefilled prompt, so
      # the box is an fzf query over an empty candidate list: type the summary,
      # Enter accepts, Esc cancels.
      summary="$(fzf --print-query --query "" \
        --prompt "󰏫 Summary ($project): " \
        --height 100% \
        --reverse \
        --border rounded \
        --border-label " 󰜢 new $type in $project " \
        --border-label-pos center \
        --header "Type the summary, then Enter (Esc to cancel)" \
        < /dev/null)"
      rc=$?
      # 0 = match accepted, 1 = query accepted (no match); anything else (130
      # Esc, 2 error) means cancel.
      [[ $rc -ne 0 && $rc -ne 1 ]] && exit 0
      summary="$(printf '%s\n' "$summary" | head -1)"
      [[ -z "$summary" ]] && exit 0

      create_args=(--project "$project" --type "$type" --summary "$summary")

      adddesc="$(printf '%s\n' "No" "Yes" | fzf \
        --prompt "󰏫 Add description: " \
        --height 100% \
        --reverse \
        --border rounded)"
      desc_file=""
      if [[ "$adddesc" == "Yes" ]]; then
        desc_file="$(mktemp)"
        nvim "$desc_file"
        [[ -s "$desc_file" ]] && create_args+=(--description-file "$desc_file")
      fi

      out=$(acli jira workitem create "${create_args[@]}" 2>&1)
      printf '%s\n' "$out"
      [[ -n "$desc_file" ]] && rm -f "$desc_file"
      read -n 1 -s -r -p "Press any key to continue..."
      ;;

    link)
      # Render the work item's existing links as tab-delimited rows:
      #   <linkId>\t<linkedKey>\t<display>
      # The two machine fields stay hidden from the picker (--with-nth 3) but
      # remain addressable in bindings via {1}/{2} (extracted from the
      # original line). An empty list yields a single placeholder row.
      rows="$(acli jira workitem view "$key" --fields issuelinks --json 2>/dev/null | jq -r '
        def pad(s; n): (s + (" " * 60))[0:n];
        def color(c):
          {
            green: "32",
            yellow: "33",
            "blue-gray": "34",
            brown: "33",
            "medium-gray": "37",
            "warm-red": "31"
          }[c] // "37";
        (.fields.issuelinks // []) as $links
        | if ($links | length) == 0 then
            "\t\t(no links, use alt-n to create a new link)"
          else
            $links[]
            | select(.outwardIssue or .inwardIssue)
            | (if .outwardIssue
               then {dir: (.type.outward // .type.name), iss: .outwardIssue}
               else {dir: (.type.inward // .type.name), iss: .inwardIssue} end) as $l
            | ($l.iss.fields.status.statusCategory.colorName // "medium-gray") as $c
            | (.id // "") + "\t" + ($l.iss.key // "") + "\t"
              + pad(($l.dir // "-"); 16) + " "
              + pad(($l.iss.key // "-"); 12) + " "
              + "\u001b[" + color($c) + "m" + pad(($l.iss.fields.status.name // "-"); 14) + "\u001b[0m" + " "
              + (($l.iss.fields.summary // "-") | gsub("[\t\n\r]"; " "))
          end
      ')"

      out="$(printf '%s\n' "$rows" | fzf \
        --ansi \
        --delimiter $'\t' \
        --with-nth 3 \
        --prompt "󰌹 Links $key: " \
        --height 100% \
        --reverse \
        --border rounded \
        --expect=alt-n,alt-d)"
      [[ $? -ne 0 ]] && exit 0

      pressed="$(printf '%s\n' "$out" | sed -n '1p')"
      selline="$(printf '%s\n' "$out" | sed -n '2p')"
      linkid="$(printf '%s' "$selline" | cut -f1)"
      linkedkey="$(printf '%s' "$selline" | cut -f2)"

      case "$pressed" in
        alt-d)
          [[ -z "$linkid" ]] && exit 0
          confirm="$(printf '%s\n' "No" "Yes" | fzf \
            --prompt "󰩺 Delete link to ${linkedkey:-?}: " \
            --height 100% \
            --reverse \
            --border rounded)"
          [[ "$confirm" != "Yes" ]] && exit 0
          if ! acli jira workitem link delete --id "$linkid" --yes; then
            read -n 1 -s -r -p "Press any key to continue..."
          fi
          ;;

        alt-n)
          # 1. Pick a target work item from the project (project-wide recent
          #    query through the same renderer), excluding the current key.
          #    --print-query lets a typed key that isn't in the window be used.
          target_rows="$("$SCRIPT" __list "project = $FZFJIRA_PROJECT AND statusCategory != Done ORDER BY updated DESC" 2>/dev/null \
            | awk -v k="$key" 'NF && $1 != k')"
          tsel="$(printf '%s\n' "$target_rows" | fzf \
            --ansi \
            --print-query \
            --prompt "󰌹 Link $key: " \
            --header "KEY          STATUS         SUMMARY" \
            --height 100% \
            --reverse \
            --border rounded)"
          case $? in
            0) target="$(printf '%s\n' "$tsel" | sed -n '2p' | awk '{print $1}')" ;;
            1) target="$(printf '%s\n' "$tsel" | sed -n '1p' | tr -d '[:space:]')" ;;
            *) exit 0 ;;
          esac
          [[ -z "$target" ]] && exit 0

          # 2. Pick a directional link type from the curated list.
          ltypes=()
          if [[ -n "$FZFJIRA_LINK_TYPES" ]]; then
            while IFS= read -r ltline; do
              [[ -n "$ltline" ]] && ltypes+=("$ltline")
            done <<< "$FZFJIRA_LINK_TYPES"
          else
            ltypes=("${FZFJIRA_DEFAULT_LINK_TYPES[@]}")
          fi

          ltlabel="$(printf '%s\n' "${ltypes[@]%%|*}" | fzf \
            --prompt "󰌹 $key … $target: " \
            --height 100% \
            --reverse \
            --border rounded)"
          [[ -z "$ltlabel" ]] && exit 0

          ltname=""
          ltdir=""
          for lt in "${ltypes[@]}"; do
            if [[ "${lt%%|*}" == "$ltlabel" ]]; then
              rest="${lt#*|}"
              ltname="${rest%%|*}"
              ltdir="${rest##*|}"
              break
            fi
          done
          [[ -z "$ltname" ]] && exit 0

          # 3. Determine the desired Jira outward/inward roles for this link.
          #    For an "out" direction (e.g. "blocks") the viewed item is the
          #    outward/source side; for "in" (e.g. "is blocked by") it is inward.
          if [[ "$ltdir" == "in" ]]; then
            jira_out="$target"
            jira_in="$key"
          else
            jira_out="$key"
            jira_in="$target"
          fi
          # acli's --out/--in flags are inverted relative to Jira's outward/
          # inward direction (verified against the Jira web UI): --out sets the
          # inward issue and --in sets the outward issue. Pass the Jira roles
          # swapped so the link is created in the intended direction.
          if ! acli jira workitem link create \
            --out "$jira_in" --in "$jira_out" --type "$ltname" --yes; then
            read -n 1 -s -r -p "Press any key to continue..."
          fi
          ;;

        *)
          # enter (or any other accept): open the linked work item.
          [[ -z "$linkedkey" ]] && exit 0
          acli jira workitem view "$linkedkey" --fields "*all" | nvim -R -
          ;;
      esac
      ;;

    *)
      echo "Unknown action: $action"
      exit 1
      ;;
  esac
  exit 0
fi

# ---------- Main mode ----------

usage() {
  cat <<'EOF'
fzfjira - Fuzzy Finder for Jira (acli)

Usage: fzfjira [JQL]

Examples:
  fzfjira
  fzfjira "project = CORE AND status != Done ORDER BY updated DESC"
  fzfjira "assignee = currentUser() AND sprint in openSprints()"

If no JQL is given, a picker of named filters is shown
(Current, Assigned, Backlog). Edit the FZFJIRA_DEFAULT_FILTERS
array in this script, or override via the FZFJIRA_FILTERS env
var, to configure them.

Keybindings:
  enter   : view the work item (opens in nvim)
  alt-a   : assign the work item (@me / default / remove / custom)
  alt-t   : transition the work item (pick a status)
  alt-c   : add a comment to the work item (opens in nvim)
  alt-e   : edit the work item (type / summary / description)
  alt-p   : set / change the work item's parent Epic (pick a project Epic)
  alt-f   : flag / unflag the work item (Impediment)
  alt-n   : create a new work item
  alt-l   : manage links (list / delete / create)
  alt-s   : show the work item's sub-tasks in a nested picker
  alt-o   : open the work item in the web browser
  alt-r   : reload the list
  ctrl-p  : toggle preview
  ctrl-d  : half page down
  ctrl-u  : half page up
  ctrl-f  : preview half page down
  ctrl-b  : preview half page up

The preview shows the work item details, a flag indicator (if flagged), its
parent (e.g. the Epic), its sub-tasks, its links, and its comment thread.

When a work item has sub-tasks, alt-s opens them in a nested picker (a new
fzfjira list scoped to `parent = <key>`) where every action above is available.

Setting the Epic (alt-p) and flagging (alt-f) are not supported by acli, so
they call the Jira REST API directly, reusing the OAuth token acli stored in
the macOS keychain (requires `security`, `curl`, and a prior
`acli jira auth login --web`).

In the links picker (alt-l):
  enter   : open the linked work item
  alt-d   : delete the highlighted link (after confirmation)
  alt-n   : create a new link (pick a target work item, then a link type)
  esc     : back to the list

Environment:
  FZFJIRA_LIMIT      Max work items to fetch (default: 250)
  FZFJIRA_PROJECT    Project for newly created work items (default: CORE)
  FZFJIRA_FLAG_FIELD Custom field id backing the "Flagged" field, used by the
                  flag action (alt-f) and the preview indicator
                  (default: customfield_10002)
  FZFJIRA_FILTERS    Override the filter picker entries. Newline-separated
                  "Name|JQL" entries, e.g.
                  $'Mine|assignee = currentUser()\nBugs|type = Bug'
  FZFJIRA_STATUSES   Comma-separated transition statuses
                  (default: CORE project statuses, e.g.
                  "Open,Backlog,In Progress,In Review,Done,Won't do")
  FZFJIRA_LINK_TYPES Override the link-type picker entries. Newline-separated
                  "Label|TypeName|direction" entries, where direction is
                  "out" (selected item is the outward side) or "in"
                  (selected item is the inward side), e.g.
                  $'blocks|Blocks|out\nis blocked by|Blocks|in'
EOF
}

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  usage
  exit 0
fi

if [[ -n "$1" ]]; then
  # An explicit JQL argument bypasses the filter picker.
  FZFJIRA_JQL="$1"
else
  # Filters come from the FZFJIRA_FILTERS env var (newline-separated "Name|JQL"
  # entries) when set, otherwise from the baked defaults.
  filters=()
  if [[ -n "$FZFJIRA_FILTERS" ]]; then
    while IFS= read -r line; do
      [[ -n "$line" ]] && filters+=("$line")
    done <<< "$FZFJIRA_FILTERS"
  else
    filters=("${FZFJIRA_DEFAULT_FILTERS[@]}")
  fi

  # No JQL given: pick from the configured named filters.
  selected=$(printf '%s\n' "${filters[@]%%|*}" | fzf \
    --prompt "󰈲 Filter: " \
    --height 100% \
    --reverse \
    --border rounded \
    --border-label " 󰌪 Jira Filters " \
    --border-label-pos center)
  [[ -z "$selected" ]] && exit 0

  FZFJIRA_JQL=""
  for f in "${filters[@]}"; do
    if [[ "${f%%|*}" == "$selected" ]]; then
      FZFJIRA_JQL="${f#*|}"
      break
    fi
  done
  [[ -z "$FZFJIRA_JQL" ]] && exit 1
fi

export FZFJIRA_JQL
export FZFJIRA_LIMIT
export FZFJIRA_STATUSES
export FZFJIRA_PROJECT
export FZFJIRA_FLAG_FIELD
export FZFJIRA_LINK_TYPES

# Pre-flight: validate the query / auth and bail out cleanly on errors or no
# results, rather than dropping into an empty picker.
ROWS="$("$SCRIPT" __list)" || exit 1
if [[ -z "$ROWS" ]]; then
  echo "No work items found for JQL: $FZFJIRA_JQL" >&2
  exit 1
fi

ACTION="$SCRIPT __action"

clear
fzf \
  --ansi \
  --reverse \
  --height 100% \
  --info right \
  --header "KEY          STATUS         SUMMARY" \
  --prompt "󰌪 Jira: " \
  --pointer ">" \
  --border "rounded" \
  --border-label " 󰌪 $FZFJIRA_JQL " \
  --border-label-pos center \
  --bind "ctrl-d:half-page-down" \
  --bind "ctrl-u:half-page-up" \
  --bind "ctrl-f:preview-half-page-down" \
  --bind "ctrl-b:preview-half-page-up" \
  --bind "ctrl-p:toggle-preview" \
  --bind "alt-r:reload($SCRIPT __list)" \
  --bind "enter:execute($ACTION view {1})" \
  --bind "alt-a:execute($ACTION assign {1})+reload($SCRIPT __list)" \
  --bind "alt-t:execute($ACTION transition {1})+reload($SCRIPT __list)" \
  --bind "alt-c:execute($ACTION comment {1})+refresh-preview" \
  --bind "alt-e:execute($ACTION edit {1})+reload($SCRIPT __list)+refresh-preview" \
  --bind "alt-p:execute($ACTION epic {1})+refresh-preview" \
  --bind "alt-f:execute($ACTION flag {1})+refresh-preview" \
  --bind "alt-n:execute($ACTION create)+reload($SCRIPT __list)" \
  --bind "alt-l:execute($ACTION link {1})+refresh-preview" \
  --bind "alt-s:execute($ACTION subtasks {1})+reload($SCRIPT __list)+refresh-preview" \
  --bind "alt-o:execute($ACTION web {1})" \
  --preview-window "right:65%" \
  --preview "$SCRIPT __preview {1}" \
  <<< "$ROWS"
