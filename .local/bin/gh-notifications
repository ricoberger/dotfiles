  --silent \
  -X POST \
  -H 'Host: api.github.com' \
  -H 'GraphQL-Features: merge_queue,private_profile_setting,project_next_field_configuration,issues_close_state,project_next_recent_connection,file_level_commenting,issue_types,sub_issues,copilot_iap_max_sku,cotd_graphql_injection,graphql_pr_comment_positioning,issues_copilot_assignment_api_support' \
