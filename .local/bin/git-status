#!/usr/bin/env bash

# git-status - Fuzzy Finder for git (stage / unstage / commit)
#
# Usage: git-status

# ---------- Main mode ----------

usage() {
  cat <<'EOF'
git-status - Fuzzy Finder for git (stage / unstage / commit)

Usage: git-status

Browse the working tree's changed files in fzf: stage / unstage them, inspect
their diff or blame in the preview, and commit straight from the picker. The
prompt toggles between an "add" view (modified / deleted / untracked files) and
a "reset" view (staged files).

Keybindings:
  enter  : stage (add view) or unstage (reset view) selection
  alt-s  : toggle between add and reset views
  alt-p  : stage selection interactively
  alt-c  : commit staged changes (git commit)
  alt-a  : amend staged changes to the last commit (git commit --amend)
  alt-e  : open selection in $EDITOR
  alt-d  : show diff in the preview
  alt-b  : show blame in the preview
  ctrl-p : toggle preview
  ctrl-d : scroll half page down
  ctrl-u : scroll half page up
  ctrl-f : scroll preview half page down
  ctrl-b : scroll preview half page up
  home   : scroll preview to top
  end    : scroll preview to bottom
  alt-h  : show help
EOF
}

if [[ "$1" == "-h" || "$1" == "--help" ]]; then
  usage
  exit 0
fi

prompt_add=" Add: "
prompt_reset=" Reset: "

git_root_dir="$(git rev-parse --show-toplevel)"
git_unstaged_files="git ls-files --modified --deleted --other --exclude-standard --deduplicate $git_root_dir"
git_staged_files='git status --short | grep "^[A-Z]" | awk "{print \$NF}"'

git_reset="git reset -- {+}"
enter_cmd="($git_unstaged_files | grep {} && git add {+}) || $git_reset"

mode_reset="change-prompt($prompt_reset)+reload($git_staged_files)+unbind(alt-p)"
mode_add="change-prompt($prompt_add)+reload($git_unstaged_files)+rebind(alt-p)"

# On-demand keybindings overlay: alt-h shows the usage() help in a pager, so the
# picker view stays uncluttered. Exported so fzf's execute child shell can read
# it.
help_text="$(usage)"
export help_text

clear
eval "$git_unstaged_files" | fzf \
  --ansi \
  --multi \
  --reverse \
  --no-sort \
  --height 100% \
  --info right \
  --prompt "$prompt_add" \
  --pointer ">" \
  --marker "󰄲" \
  --border "rounded" \
  --border-label "  $(pwd)/ " \
  --border-label-pos center \
  --bind "ctrl-d:half-page-down" \
  --bind "ctrl-u:half-page-up" \
  --bind "ctrl-f:preview-half-page-down" \
  --bind "ctrl-b:preview-half-page-up" \
  --bind "home:preview-top" \
  --bind "end:preview-bottom" \
  --bind "ctrl-p:toggle-preview" \
  --bind "alt-s:transform:[[ \$FZF_PROMPT =~ '$prompt_add' ]] && echo '$mode_reset' || echo '$mode_add'" \
  --bind "alt-d:change-preview(git diff --no-ext-diff -- {} 2>/dev/null | grep -q . && git diff --no-ext-diff --color -- {} || bat --style=numbers --color=always {})" \
  --bind "alt-b:change-preview(git blame --color-by-age {})" \
  --bind "enter:execute($enter_cmd)" \
  --bind "enter:+reload([[ \$FZF_PROMPT =~ '$prompt_add' ]] && $git_unstaged_files || $git_staged_files)" \
  --bind "enter:+refresh-preview" \
  --bind "alt-p:execute(git add --patch {+})" \
  --bind "alt-p:+reload($git_unstaged_files)" \
  --bind "alt-c:execute(git commit)+abort" \
  --bind "alt-a:execute(git commit --amend)+abort" \
  --bind "alt-e:execute(\${EDITOR:-vim} {+})" \
  --bind "alt-h:execute(printf '%s\n' \"\$help_text\" | less -R)" \
  --preview-window "right:65%" \
  --preview "git diff --no-ext-diff -- {} 2>/dev/null | grep -q . && git diff --no-ext-diff --color -- {} || bat --style=numbers --color=always {}"
